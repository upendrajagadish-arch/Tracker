# Hosted Supabase (recommended without Docker)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Setup scripts only (npm run supabase:seed-users) — never use in Vite/client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local Supabase alternative (requires Docker Desktop + `npx supabase start`):
